{
  "builds": [{"src": "**/*", "use": "@vercel/static"}],
  "routes": [
    {"handle": "filesystem"},
    {"src": "/(.*)", "dest": "/index.html"}
  ],
  "headers": [
    {"source": "/index.html", "headers": [{"key": "Cache-Control", "value": "public, max-age=0, must-revalidate"}]},
    {"source": "/(.*)\\.jpg", "headers": [{"key": "Cache-Control", "value": "public, max-age=604800"}]},
    {"source": "/(.*)\\.webp", "headers": [{"key": "Cache-Control", "value": "public, max-age=604800"}]},
    {"source": "/(.*)\\.png", "headers": [{"key": "Cache-Control", "value": "public, max-age=604800"}]}
  ]
}
